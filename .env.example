# Auth.js (NextAuth v5)
AUTH_SECRET=
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Comma-separated list of Discord IDs that should be granted ADMIN on first login
ADMIN_DISCORD_IDS=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=screenshots

# Database (Supabase Postgres connection string used by Drizzle)
DATABASE_URL=

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.gg/sQfF3r6NvZ

# Discord webhooks (one-time info post via scripts/discord-post-info.ts)
DISCORD_WEBHOOK_NTL=
DISCORD_WEBHOOK_ANNOUNCE=
DISCORD_WEBHOOK_ROSTER=
